{"acceptance_criteria":"","actor":"","agent_state":"","assignee":null,"await_id":"","await_type":"","close_reason":"","closed_at":null,"closed_by_session":"","compacted_at":null,"compacted_at_commit":null,"compaction_level":0,"content_hash":"779081b2a7736e447efdf8f6f4bc4b9be91975a54c4e62d5e4a8e8be23ec950e","created_at":"2026-03-24T03:07:25Z","created_by":"Jake Englund","crystallizes":0,"defer_until":null,"description":"Remove the WAN firewall restriction for Harmony traffic. The current firewall blocks UDP 4242 on WAN — but with Harmony's E2E encryption (Reticulum, ML-KEM, ML-DSA), there is no meaningful trust difference between LAN and WAN. Any Harmony/Zenoh/Reticulum peer on the other side of the WAN port should 'just work'. Implementation: allow Harmony protocol traffic (UDP 4242 for Reticulum, Zenoh scouting ports, iroh-net QUIC) through the WAN zone. The firewall disappears for Harmony connections while remaining active for non-Harmony traffic.","design":"","due_at":null,"ephemeral":0,"estimated_minutes":null,"event_kind":"","external_ref":null,"hook_bead":"","id":"harmony-openwrt-4jl","is_template":0,"issue_type":"feature","last_activity":null,"metadata":"{}","mol_type":"","notes":"","original_size":null,"owner":"zeblith@gmail.com","payload":"","pinned":0,"priority":1,"quality_score":null,"rig":"","role_bead":"","role_type":"","sender":"","source_repo":"","source_system":"","spec_id":"","status":"open","target":"","timeout_ns":0,"title":"Firewall-free WAN for Harmony protocols","updated_at":"2026-03-24T03:07:25Z","waiters":"","wisp_type":"","work_type":""}
